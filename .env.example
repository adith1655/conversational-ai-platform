# ══════════════════════════════════════════════════════════════
#  Green Grass Heritage — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────
# Choose ONE provider below. Comment out the others.

# ── OPTION 1: Google Gemini (FREE tier — recommended) ─────────
# Get a free API key at: https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-1.5-flash
# Other Gemini models: gemini-1.5-pro  |  gemini-2.0-flash-exp

# ── OPTION 2: Ollama (local, fully free, no API key) ──────────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.2
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=

# ── OPTION 3: OpenAI (paid) ───────────────────────────────────
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# ── Optional Settings ─────────────────────────────────────────
# DEBUG=false
# MAX_TURNS_IN_CONTEXT=20
